{
  "name": "schibsted-and-vend-blocker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Schibsted & Vend blocker extension for Firefox and Chrome",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "start:firefox": "web-ext run --source-dir dist/firefox",
    "start:chrome": "web-ext run --target chromium --source-dir dist/chrome",
    "package:firefox": "web-ext build --source-dir dist/firefox --artifacts-dir web-ext-artifacts/firefox --overwrite-dest",
    "package:chrome": "web-ext build --source-dir dist/chrome --artifacts-dir web-ext-artifacts/chrome --overwrite-dest",
    "package": "npm run package:firefox && npm run package:chrome",
    "lint": "web-ext lint --source-dir dist/firefox"
  },
  "devDependencies": {
    "vite": "^6.0.0",
    "web-ext": "^8.3.0"
  }
}
