{
  "manifest_version": 3,
  "name": "Schibsted & Vend Blocker",
  "version": "1.0.2",
  "description": "Schibsted & Vend blocker extension",
  "icons": {
    "16": "icons/logo-16.png",
    "48": "icons/logo-48.png",
    "128": "icons/logo-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://vg.no/*",
        "https://*.vg.no/*",
        "https://aftenposten.no/*",
        "https://*.aftenposten.no/*",
        "https://e24.no/*",
        "https://*.e24.no/*",
        "https://bt.no/*",
        "https://*.bt.no/*",
        "https://aftenbladet.no/*",
        "https://*.aftenbladet.no/*",
        "https://aftonbladet.se/*",
        "https://*.aftonbladet.se/*",
        "https://svd.se/*",
        "https://*.svd.se/*",
        "https://omni.se/*",
        "https://*.omni.se/*",
        "https://tv4.se/*",
        "https://*.tv4.se/*",
        "https://fotbollskanalen.se/*",
        "https://*.fotbollskanalen.se/*"
      ],
      "css": ["content-scripts/schibsted-and-vend-blocker.css"],
      "js": ["content-scripts/schibsted-and-vend-blocker.js"],
      "run_at": "document_idle"
    }
  ]
}
